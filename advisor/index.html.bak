<!DOCTYPE html>
<html lang="zh-TW">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>畢製管理 · 老師總覽</title>
  <link rel="stylesheet" href="../shared/dashboard.css">

  <!-- PWA -->
  <link rel="manifest" href="./manifest.json">
  <meta name="theme-color" content="#1a1a1a">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="畢製管理">
  <link rel="apple-touch-icon" href="../shared/icons/icon-192.png">

  <style>
    /* ── Milestones 區塊（advisor 專用） ── */
    .ms-list {
      display: flex;
      flex-direction: column;
    }

    .ms-item {
      padding: 11px 18px;
      border-bottom: 1px solid var(--border-light);
      display: grid;
      grid-template-columns: 60px 1fr auto auto;
      align-items: center;
      gap: 14px;
    }

    .ms-item:last-child {
      border-bottom: none;
    }

    .ms-item.past {
      opacity: .55;
    }

    .ms-item.current {
      background: var(--surface-2);
    }

    .ms-title {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.04em;
    }

    .ms-desc {
      font-size: 11px;
      color: var(--text-muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .ms-due {
      font-size: 10px;
      color: var(--text-dim);
      font-variant-numeric: tabular-nums;
    }

    .ms-progress {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 110px;
    }

    .ms-progress-track {
      width: 60px;
      height: 2px;
      background: var(--border-light);
      border-radius: 1px;
      overflow: hidden;
    }

    .ms-progress-fill {
      height: 100%;
      background: var(--text-muted);
      border-radius: 1px;
    }

    .ms-progress-num {
      font-size: 10px;
      color: var(--text-muted);
      font-variant-numeric: tabular-nums;
    }

    .ms-tag {
      font-size: 9px;
      padding: 1px 6px;
      border: 1px solid var(--border);
      border-radius: 2px;
      letter-spacing: 0.04em;
      color: var(--text-muted);
    }

    .ms-tag.now {
      color: var(--text);
      border-color: var(--text);
    }

    .ms-tag.done {
      color: var(--ok);
      border-color: #7cbf9e;
      background: var(--ok-bg);
    }

    @media (max-width: 700px) {
      .ms-item {
        grid-template-columns: 1fr;
        gap: 4px;
      }

      .ms-desc {
        white-space: normal;
      }
    }

    /* ── Calendar: milestone 標示 ── */
    .cal-day.has-milestone {
      background: #fdecec;
    }

    .cal-day.has-milestone .cal-day-num {
      color: #b03a3a;
      font-weight: 600;
    }

    .cal-day.has-milestone:hover {
      background: #fbdcdc;
    }

    /* today + milestone 重疊時:今天的深底為主,加紅色外框讓 milestone 仍可辨識 */
    .cal-day.today.has-milestone {
      background: var(--text);
      outline: 1.5px solid #b03a3a;
      outline-offset: -1.5px;
    }

    .cal-day.today.has-milestone .cal-day-num {
      color: #ffb4b4;
    }

    /* 過去日期上的 milestone:全淡掉,不再警示 */
    .cal-day.has-milestone.ms-past {
      background: transparent;
    }

    .cal-day.has-milestone.ms-past .cal-day-num {
      color: var(--text-dim);
      font-weight: 400;
    }

    /* milestone 小標(在格子下方) */
    .cal-ms-label {
      position: absolute;
      bottom: 2px;
      left: 0;
      right: 0;
      font-size: 8px;
      color: #b03a3a;
      text-align: center;
      letter-spacing: 0.02em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      padding: 0 2px;
      pointer-events: none;
    }

    .cal-day.today.has-milestone .cal-ms-label {
      color: #ffb4b4;
    }

    .cal-day.has-milestone.ms-past .cal-ms-label {
      display: none;
    }
  </style>
</head>

<body>

  <header class="site-header">
    <div class="header-brand">
      <span class="brand-name">畢製管理 2026</span>
      <span class="brand-badge">老師總覽</span>
    </div>
    <div class="header-meta">
      <span class="live-dot"></span>
      <span id="hd-rate">—</span>
      <span>·</span>
      <span id="hd-clock">—</span>
    </div>
  </header>

  <main class="main">

    <div class="token-bar">
      <label>GitHub PAT</label>
      <input class="token-input" id="tok-input" type="password" placeholder="ghp_... (可選，提高 API 限額至 5000/hr)">
      <button class="token-btn" onclick="applyToken()">套用</button>
      <span class="rate-hint" id="rate-hint">未認證 · 60 次/hr</span>
    </div>

    <div id="error-box" class="notice warn" style="display:none"></div>

    <div class="week-banner">
      <div class="wb-block">
        <div class="wb-label">目前進度</div>
        <div class="wb-value" id="wb-week">—</div>
        <div class="wb-sub" id="wb-day">—</div>
      </div>
      <div class="wb-progress">
        <div class="wb-prog-row">
          <span>2026-02-23</span>
          <span id="wb-pct">0%</span>
        </div>
        <div class="wb-track">
          <div class="wb-fill" id="wb-fill" style="width:0%"></div>
        </div>
      </div>
      <div class="wb-block wb-right" style="display:flex;flex-direction:column;gap:10px;text-align:right;">
        <div>
          <div class="wb-label">距校內展 <span style="opacity:.5;font-size:9px;">10/13</span></div>
          <div style="display:flex;align-items:baseline;justify-content:flex-end;gap:5px;">
            <div class="wb-value" id="wb-cd-inner">—</div>
            <div class="wb-sub">天</div>
          </div>
        </div>
        <div>
          <div class="wb-label">距校外展 <span style="opacity:.5;font-size:9px;">12/04</span></div>
          <div style="display:flex;align-items:baseline;justify-content:flex-end;gap:5px;">
            <div class="wb-value" id="wb-cd-outer">—</div>
            <div class="wb-sub">天</div>
          </div>
        </div>
      </div>
    </div>

    <div class="card timeline-wrap" style="margin-bottom:20px;">
      <div class="section-label">45 週時間軸</div>
      <div class="tl-grid" id="tl-grid" style="--tl-cols:45"></div>
    </div>

    <div class="section-label">各組狀態</div>
    <div class="teams-grid" id="teams-grid">
      <div class="loading-text">從 GitHub Issues 載入中⋯</div>
    </div>

    <div class="section-label">Milestones</div>
    <div class="card" id="ms-card" style="margin-bottom:20px;">
      <div class="loading-text">從 GitHub 載入 milestones⋯</div>
    </div>

    <div class="section-label">行事曆</div>
    <div class="cal-wrap" id="cal-wrap"></div>

  </main>

  <script>
    const OWNER = 'seraphwu';
    const REPO = 'grad-project-2026';
    const START = new Date('2026-02-23T00:00:00+08:00');
    const END = new Date('2027-01-03T23:59:59+08:00');
    const INNER_SHOW = new Date('2026-10-13T23:59:59+08:00'); // 校內展
    const OUTER_SHOW = new Date('2026-12-04T23:59:59+08:00'); // 校外展
    const TOTAL_WKS = 45;
    const MS_WEEKS = { 34: '校內展', 41: '校外展' };

    // TEAMS 從 shared/teams.json 載入；fallback 萬一 fetch 失敗才用空物件
    let TEAMS = {};

    let ghToken = localStorage.getItem('gh_pat') || '';
    let allIssues = [];

    const $ = id => document.getElementById(id);
    const tw = () => new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Taipei' }));

    // 把 role 規範成字串(可能是 string 或 array)
    function roleToText(role) {
      if (Array.isArray(role)) return role.join(' / ');
      return role || '';
    }

    // 把 github username 規範成 @xxx 格式 (teams.json 不帶 @)
    function ghHandle(github) {
      if (!github) return '';
      return github.startsWith('@') ? github : '@' + github;
    }

    async function loadTeams() {
      try {
        const res = await fetch('../shared/teams.json', { cache: 'no-cache' });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        // schema: { teams: { 'team:a': {...}, 'team:b': {...} } }
        TEAMS = data.teams || {};
      } catch (e) {
        console.warn('[teams.json] 載入失敗:', e.message);
        showError(`teams.json 載入失敗（${e.message}）。各組狀態無法顯示。`);
        TEAMS = {};
      }
    }

    function weekInfo() {
      const now = tw();
      const diff = now - START;
      const days = Math.floor(diff / 86400000);
      if (days < 0) return { before: true, daysUntil: -days };
      if (now > END) return { after: true };
      const week = Math.floor(days / 7) + 1;
      const dayOfWeek = (days % 7) + 1;
      const pct = Math.min(100, Math.round((days / (TOTAL_WKS * 7)) * 100));
      const cdInner = Math.max(0, Math.ceil((INNER_SHOW - now) / 86400000));
      const cdOuter = Math.max(0, Math.ceil((OUTER_SHOW - now) / 86400000));
      return { week, dayOfWeek, pct, cdInner, cdOuter };
    }

    function apiHeaders() {
      const h = { Accept: 'application/vnd.github+json' };
      if (ghToken) h.Authorization = `Bearer ${ghToken}`;
      return h;
    }

    async function ghFetch(path) {
      const r = await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/${path}`, { headers: apiHeaders() });
      const rem = r.headers.get('X-RateLimit-Remaining');
      const lim = r.headers.get('X-RateLimit-Limit');
      if (rem !== null) $('hd-rate').textContent = `API ${rem}/${lim}`;
      if (!r.ok) throw new Error(`${r.status} ${r.statusText}`);
      return r.json();
    }

    async function fetchAllIssues() {
      let page = 1, acc = [];
      while (true) {
        const batch = await ghFetch(`issues?state=all&per_page=100&page=${page}`);
        if (!batch.length) break;
        acc = acc.concat(batch);
        if (batch.length < 100) break;
        page++;
      }
      return acc;
    }

    async function fetchMilestones() {
      // GitHub API 一頁最多 100,通常 milestones 不會破百
      return await ghFetch('milestones?state=all&per_page=100&sort=due_on&direction=asc');
    }

    const labels = i => i.labels.map(l => l.name);
    const issueWeek = i => labels(i).find(l => /^W\d+$/.test(l)) || null;
    const issueTeam = i => labels(i).find(l => l.startsWith('team:')) || null;
    const isBlocked = i => labels(i).includes('status:blocked');

    // ── Clock ──
    function updateClock() {
      $('hd-clock').textContent = tw().toLocaleString('zh-TW', {
        month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit'
      });
    }
    setInterval(updateClock, 30000);
    updateClock();

    // ── Token ──
    function applyToken() {
      const v = $('tok-input').value.trim();
      if (v) { ghToken = v; localStorage.setItem('gh_pat', v); $('rate-hint').textContent = '已套用 PAT · 5000 次/hr'; }
      loadAll();
    }
    if (ghToken) { $('tok-input').value = ghToken; $('rate-hint').textContent = '已套用 PAT · 5000 次/hr'; }

    // ── Week Banner ──
    function renderWeekBanner() {
      const info = weekInfo();
      if (info.before) {
        $('wb-week').textContent = '尚未開始';
        $('wb-day').textContent = `${info.daysUntil} 天後啟動`;
        $('wb-cd-inner').textContent = '—';
        $('wb-cd-outer').textContent = '—';
        return;
      }
      if (info.after) {
        $('wb-week').textContent = '已完成';
        $('wb-day').textContent = `共 ${TOTAL_WKS} 週`;
        $('wb-pct').textContent = '100%';
        $('wb-fill').style.width = '100%';
        $('wb-cd-inner').textContent = '0';
        $('wb-cd-outer').textContent = '0';
        return;
      }
      $('wb-week').textContent = `第 ${info.week} 週`;
      $('wb-day').textContent = `第 ${info.dayOfWeek} 天`;
      $('wb-pct').textContent = `${info.pct}%`;
      $('wb-fill').style.width = `${info.pct}%`;
      $('wb-cd-inner').textContent = info.cdInner;
      $('wb-cd-outer').textContent = info.cdOuter;
    }

    // ── Timeline ──
    function renderTimeline() {
      const { week: cur } = weekInfo();
      const grid = $('tl-grid');
      grid.innerHTML = '';
      for (let w = 1; w <= TOTAL_WKS; w++) {
        const isCur = w === cur;
        const isPast = w < (cur || 0);
        const isMs = !!MS_WEEKS[w];
        const info = weekInfo();
        const fillW = isCur
          ? `${((info.dayOfWeek - 1) / 7) * 100}%`
          : isPast ? '100%' : '0%';
        const cell = document.createElement('div');
        cell.className = `tl-cell ${isCur ? 'current' : isPast ? 'past' : 'future'}${isMs ? ' ms' : ''}`;
        cell.innerHTML = `
      <div class="tl-bar"><div class="tl-bar-fill" style="width:${fillW}"></div></div>
      <div class="tl-wlabel">${MS_WEEKS[w] || 'W' + w}</div>`;
        grid.appendChild(cell);
      }
    }

    // ── Teams ──
    function renderTeams(issues) {
      const grid = $('teams-grid');
      grid.innerHTML = '';

      const teamEntries = Object.entries(TEAMS);
      if (teamEntries.length === 0) {
        grid.innerHTML = `<div class="loading-text">teams.json 沒有組別資料</div>`;
        return;
      }

      const info = weekInfo();
      const curWk = info.week ? `W${info.week}` : null;

      for (const [tid, team] of teamEntries) {
        const tIssues = issues.filter(i => issueTeam(i) === tid);
        const open = tIssues.filter(i => i.state === 'open');
        const closed = tIssues.filter(i => i.state === 'closed');
        const blocked = open.filter(isBlocked);
        const thisWk = curWk ? open.filter(i => labels(i).includes(curWk)) : [];

        const card = document.createElement('div');
        card.className = 'card';

        const recentIssues = open.slice(0, 8);
        const issueHTML = recentIssues.length === 0
          ? `<div class="loading-text">暫無進行中任務</div>`
          : recentIssues.map(i => {
            const wk = issueWeek(i);
            const lbs = labels(i).filter(l => !l.startsWith('team:') && l !== wk).slice(0, 3);
            return `
            <a class="issue-item" href="${i.html_url}" target="_blank" rel="noopener">
              <span class="issue-num">#${i.number}</span>
              <div class="issue-body">
                <div class="issue-title-text">${i.title}</div>
                <div class="chips">
                  ${wk ? `<span class="chip week">${wk}</span>` : ''}
                  ${lbs.map(l => `<span class="chip">${l}</span>`).join('')}
                  ${isBlocked(i) ? `<span class="chip blocked">卡關</span>` : ''}
                </div>
              </div>
            </a>`;
          }).join('');

        // 組別頁面連結:用 folder 欄位(/teams/team-a/),從 advisor 出發要回上層
        const teamLink = team.folder ? `..${team.folder}` : `../teams/${tid.replace(':', '-')}/`;

        const members = team.members || [];

        card.innerHTML = `
      <div class="team-card-header">
        <div class="team-display-name">${team.display_name || tid}</div>
        <div class="team-label-id">${tid}</div>
      </div>
      <div class="team-stats">
        <div class="stat"><div class="stat-lbl">本週</div><div class="stat-val">${thisWk.length}</div></div>
        <div class="stat"><div class="stat-lbl">進行中</div><div class="stat-val">${open.length}</div></div>
        <div class="stat"><div class="stat-lbl">已完成</div><div class="stat-val ok">${closed.length}</div></div>
        <div class="stat"><div class="stat-lbl">卡關</div><div class="stat-val ${blocked.length ? 'warn' : ''}">${blocked.length}</div></div>
      </div>
      <div class="issue-list">${issueHTML}</div>
      <div class="team-card-footer">
        <div class="avatars">
          ${members.map(m => {
          const handle = ghHandle(m.github);
          const ini = m.github ? m.github.slice(0, 2).toUpperCase() : '??';
          const role = roleToText(m.role);
          return `<div class="avatar" title="${handle} · ${role}">${ini}</div>`;
        }).join('')}
        </div>
        <a class="card-link" href="${teamLink}">組別頁面 →</a>
      </div>`;
        grid.appendChild(card);
      }
    }

    // ── Milestones ──
    function renderMilestones(milestones) {
      const card = $('ms-card');
      if (!milestones || milestones.length === 0) {
        card.innerHTML = `<div class="loading-text">沒有 milestones</div>`;
        return;
      }

      const now = tw();

      // 排序:有 due_on 的依日期升冪,沒有的擺最後
      const sorted = [...milestones].sort((a, b) => {
        if (!a.due_on && !b.due_on) return 0;
        if (!a.due_on) return 1;
        if (!b.due_on) return -1;
        return new Date(a.due_on) - new Date(b.due_on);
      });

      // 找「下一個未到期的」當作 current
      let currentIdx = -1;
      for (let i = 0; i < sorted.length; i++) {
        const m = sorted[i];
        if (m.state === 'open' && m.due_on && new Date(m.due_on) >= now) {
          currentIdx = i;
          break;
        }
      }

      const html = sorted.map((m, idx) => {
        const total = (m.open_issues || 0) + (m.closed_issues || 0);
        const closed = m.closed_issues || 0;
        const pct = total > 0 ? Math.round((closed / total) * 100) : 0;

        const isClosed = m.state === 'closed';
        const dueDate = m.due_on ? new Date(m.due_on) : null;
        const isPast = dueDate && dueDate < now && !isClosed;
        const isCur = idx === currentIdx;

        const cls = isClosed ? 'past' : isPast ? 'past' : isCur ? 'current' : '';

        const dueText = dueDate
          ? dueDate.toLocaleDateString('zh-TW', { month: 'numeric', day: 'numeric' })
          : '無截止日';

        const tag = isClosed
          ? `<span class="ms-tag done">已關閉</span>`
          : isCur
            ? `<span class="ms-tag now">進行中</span>`
            : isPast
              ? `<span class="ms-tag" style="color:var(--warn);border-color:var(--warn-border)">已逾期</span>`
              : `<span class="ms-tag">未開始</span>`;

        const desc = m.description ? m.description.replace(/\n/g, ' ') : '—';

        return `
      <a class="ms-item ${cls}" href="${m.html_url}" target="_blank" rel="noopener" style="text-decoration:none;color:inherit;">
        <div class="ms-title">${m.title}</div>
        <div class="ms-desc">${desc}</div>
        <div class="ms-progress">
          <div class="ms-progress-track"><div class="ms-progress-fill" style="width:${pct}%"></div></div>
          <span class="ms-progress-num">${closed}/${total}</span>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
          <span class="ms-due">${dueText}</span>
          ${tag}
        </div>
      </a>`;
      }).join('');

      card.innerHTML = `<div class="ms-list">${html}</div>`;
    }

    // ── Calendar ──
    // milestonesByDay: { 'YYYY-MM-DD': [{ title, isOpen }, ...] }  由 renderCalendars 預先算好傳進來
    function buildCalendar(year, month, issues, milestonesByDay) {
      const issueDates = {};
      issues.forEach(i => {
        const d = new Date(new Date(i.created_at).toLocaleString('en-US', { timeZone: 'Asia/Taipei' }));
        if (d.getFullYear() === year && d.getMonth() === month) {
          const day = d.getDate();
          const t = issueTeam(i);
          if (!issueDates[day]) issueDates[day] = new Set();
          if (t) issueDates[day].add(t);
        }
      });

      const todayTW = tw();
      const todayD = (todayTW.getFullYear() === year && todayTW.getMonth() === month) ? todayTW.getDate() : -1;
      const firstDay = new Date(year, month, 1).getDay();
      const daysInMo = new Date(year, month + 1, 0).getDate();
      const prevDays = new Date(year, month, 0).getDate();

      const dayNames = ['日', '一', '二', '三', '四', '五', '六'];
      let cells = dayNames.map(d => `<div class="cal-dname">${d}</div>`).join('');

      for (let i = firstDay - 1; i >= 0; i--)
        cells += `<div class="cal-day other-month"><div class="cal-day-num">${prevDays - i}</div></div>`;

      for (let d = 1; d <= daysInMo; d++) {
        const teams = issueDates[d];
        const hasDots = teams && teams.size > 0;

        // 該日是否有 milestone
        const ymd = `${year}-${String(month + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        const dayMs = milestonesByDay[ymd] || [];
        const hasMs = dayMs.length > 0;
        // 「過去日期且該日 milestone 全部已關閉」→ 視為已過去,不警示
        const isPastDay = todayD > 0 && d < todayD;
        const allClosed = dayMs.length > 0 && dayMs.every(m => !m.isOpen);
        const msPast = hasMs && isPastDay && allClosed;

        const msClasses = hasMs
          ? `has-milestone${msPast ? ' ms-past' : ''}`
          : '';

        // tooltip: 列出該日所有 milestone 標題
        const msTitle = hasMs
          ? dayMs.map(m => m.isOpen ? m.title : `${m.title} (已關閉)`).join('\n')
          : '';
        const titleAttr = msTitle ? ` title="${msTitle.replace(/"/g, '&quot;')}"` : '';

        // 格子下方的 milestone 標籤(只顯示第一個,多個用「+N」表示)
        const msLabel = hasMs && !msPast
          ? (dayMs.length > 1
            ? `<div class="cal-ms-label">${dayMs[0].title} +${dayMs.length - 1}</div>`
            : `<div class="cal-ms-label">${dayMs[0].title}</div>`)
          : '';

        cells += `
      <div class="cal-day${d === todayD ? ' today' : ''}${hasDots ? ' has-issues' : ''}${msClasses ? ' ' + msClasses : ''}"${titleAttr} style="${hasMs ? 'position:relative;' : ''}">
        <div class="cal-day-num">${d}</div>
        ${hasDots ? `<div class="cal-dots">${[...teams].map(t => `<div class="cal-dot ${t.replace(':', '-')}"></div>`).join('')}</div>` : ''}
        ${msLabel}
      </div>`;
      }

      const total = Math.ceil((firstDay + daysInMo) / 7) * 7;
      for (let i = firstDay + daysInMo, a = 1; i < total; i++, a++)
        cells += `<div class="cal-day other-month"><div class="cal-day-num">${a}</div></div>`;

      const name = new Date(year, month).toLocaleString('zh-TW', { year: 'numeric', month: 'long' });
      return { name, cells };
    }

    // 把 milestones 攤平成 { 'YYYY-MM-DD': [{title, isOpen}, ...] }
    function indexMilestonesByDay(milestones) {
      const map = {};
      if (!milestones) return map;
      for (const m of milestones) {
        if (!m.due_on) continue;
        // due_on 是 ISO 字串 (UTC),轉成台北時區的 YMD
        const d = new Date(new Date(m.due_on).toLocaleString('en-US', { timeZone: 'Asia/Taipei' }));
        const ymd = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
        if (!map[ymd]) map[ymd] = [];
        map[ymd].push({ title: m.title, isOpen: m.state === 'open' });
      }
      return map;
    }

    function renderCalendars(issues, milestones) {
      const wrap = $('cal-wrap');
      const now = tw();
      wrap.innerHTML = '';
      const msByDay = indexMilestonesByDay(milestones);
      for (let offset = 0; offset <= 1; offset++) {
        const d = new Date(now.getFullYear(), now.getMonth() + offset, 1);
        const { name, cells } = buildCalendar(d.getFullYear(), d.getMonth(), issues, msByDay);
        const card = document.createElement('div');
        card.className = 'card cal-card';
        card.innerHTML = `
      <div class="cal-month-nav"><div class="cal-month-name">${name}</div></div>
      <div class="cal-grid">${cells}</div>`;
        wrap.appendChild(card);
      }
    }

    // ── Error ──
    function showError(msg) {
      const b = $('error-box');
      b.textContent = msg;
      b.style.display = 'block';
    }

    // ── Load ──
    async function loadAll() {
      $('error-box').style.display = 'none';
      $('teams-grid').innerHTML = '<div class="loading-text">從 GitHub Issues 載入中⋯</div>';
      $('ms-card').innerHTML = '<div class="loading-text">從 GitHub 載入 milestones⋯</div>';

      // teams.json 必先載入,後續 renderTeams 才有資料用
      await loadTeams();

      renderWeekBanner();
      renderTimeline();

      // issues 跟 milestones 平行抓
      const [issuesResult, msResult] = await Promise.allSettled([
        fetchAllIssues(),
        fetchMilestones()
      ]);

      if (issuesResult.status === 'fulfilled') {
        allIssues = issuesResult.value;
        renderTeams(allIssues);
      } else {
        showError(`Issues API 錯誤：${issuesResult.reason.message}。若為 rate limit，請填入 PAT。`);
        renderTeams([]);
      }

      let milestones = [];
      if (msResult.status === 'fulfilled') {
        milestones = msResult.value;
        renderMilestones(milestones);
      } else {
        $('ms-card').innerHTML = `<div class="loading-text">Milestones 載入失敗:${msResult.reason.message}</div>`;
      }

      // calendar 需要 issues + milestones 都到位才畫
      renderCalendars(allIssues || [], milestones);
    }

    loadAll();
  </script>

  <!-- PWA Service Worker 註冊 -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('./service-worker.js')
          .then(reg => {
            console.log('[SW] 已註冊，scope:', reg.scope);
            reg.addEventListener('updatefound', () => {
              const newWorker = reg.installing;
              newWorker.addEventListener('statechange', () => {
                if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                  console.log('[SW] 新版本可用，重新整理即可更新');
                }
              });
            });
          })
          .catch(err => console.warn('[SW] 註冊失敗:', err));
      });
    }
  </script>
</body>

</html>