<!DOCTYPE html>
<html lang="zh-TW">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>畢製管理 · 組別頁</title>
  <link rel="stylesheet" href="../../shared/dashboard.css">

  <style>
    /* ── 成員列表 (組別頁專用) ── */
    .members-card {
      padding: 14px 18px;
    }

    .members-list-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 8px;
    }

    .member-chip {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 7px 10px;
      background: var(--surface-2);
      border: 1px solid var(--border-light);
      border-radius: var(--radius);
      text-decoration: none;
      color: inherit;
      transition: border-color .15s;
    }

    .member-chip:hover {
      border-color: var(--text-muted);
    }

    .member-chip-avatar {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: var(--bg);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      font-weight: 500;
      color: var(--text-muted);
      flex-shrink: 0;
    }

    .member-chip-info {
      min-width: 0;
      flex: 1;
    }

    .member-chip-name {
      font-size: 11px;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .member-chip-role {
      font-size: 9px;
      color: var(--text-muted);
      letter-spacing: 0.04em;
    }

    /* ── Milestones (簡化版,只顯示前 6 個) ── */
    .ms-mini-list {
      padding: 6px 0;
    }

    .ms-mini-item {
      padding: 8px 18px;
      border-bottom: 1px solid var(--border-light);
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: inherit;
      transition: background .1s;
    }

    .ms-mini-item:last-child {
      border-bottom: none;
    }

    .ms-mini-item:hover {
      background: var(--surface-2);
    }

    .ms-mini-item.past {
      opacity: .55;
    }

    .ms-mini-title {
      font-size: 11px;
      font-weight: 500;
      flex: 0 0 auto;
      min-width: 36px;
    }

    .ms-mini-desc {
      font-size: 11px;
      color: var(--text-muted);
      flex: 1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .ms-mini-due {
      font-size: 10px;
      color: var(--text-dim);
      font-variant-numeric: tabular-nums;
      flex-shrink: 0;
    }

    /* ── Calendar: milestone 標示 ── */
    .cal-day.has-milestone {
      background: #fdecec;
    }

    .cal-day.has-milestone .cal-day-num {
      color: #b03a3a;
      font-weight: 600;
    }

    .cal-day.has-milestone:hover {
      background: #fbdcdc;
    }

    .cal-day.today.has-milestone {
      background: var(--text);
      outline: 1.5px solid #b03a3a;
      outline-offset: -1.5px;
    }

    .cal-day.today.has-milestone .cal-day-num {
      color: #ffb4b4;
    }

    .cal-day.has-milestone.ms-past {
      background: transparent;
    }

    .cal-day.has-milestone.ms-past .cal-day-num {
      color: var(--text-dim);
      font-weight: 400;
    }

    .cal-ms-label {
      position: absolute;
      bottom: 2px;
      left: 0;
      right: 0;
      font-size: 8px;
      color: #b03a3a;
      text-align: center;
      letter-spacing: 0.02em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      padding: 0 2px;
      pointer-events: none;
    }

    .cal-day.today.has-milestone .cal-ms-label {
      color: #ffb4b4;
    }

    .cal-day.has-milestone.ms-past .cal-ms-label {
      display: none;
    }
  </style>
</head>

<body>

  <header class="site-header">
    <div class="header-brand">
      <span class="brand-name">畢製管理 2026</span>
      <span class="brand-badge" id="hd-badge">—</span>
    </div>
    <div class="header-meta">
      <span class="live-dot"></span>
      <span id="hd-rate">—</span>
      <span>·</span>
      <span id="hd-clock">—</span>
    </div>
  </header>

  <main class="main">

    <div class="token-bar" id="tok-bar" style="margin-bottom:20px;">
      <label>GitHub PAT</label>
      <input class="token-input" id="tok-input" type="password" placeholder="ghp_... (選填，提高 API 限額)">
      <button class="token-btn" onclick="applyToken()">套用</button>
      <span class="rate-hint" id="rate-hint">—</span>
    </div>

    <div id="error-box" class="notice warn" style="display:none"></div>

    <!-- Hero -->
    <div class="hero-team">
      <div class="hero-week-row">
        <div class="hero-week-num" id="hero-wnum">—</div>
        <div class="hero-week-detail">
          <div class="hero-week-lbl">目前進度</div>
          <div class="hero-day-info" id="hero-day">—</div>
        </div>
      </div>
      <div class="hero-bottom">
        <div class="hero-team-name" id="hero-tname">—</div>
        <div class="hero-prog-wrap">
          <div class="hero-prog-lbl">
            <span>進度</span>
            <span id="hero-pct">0%</span>
          </div>
          <div class="hero-track">
            <div class="hero-fill" id="hero-fill" style="width:0%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- 組員 -->
    <div class="section-label">組員</div>
    <div class="card members-card" id="members-card" style="margin-bottom:20px;">
      <div class="loading-text">載入中⋯</div>
    </div>

    <!-- 本週任務 -->
    <div class="section-label">本週任務</div>
    <div class="card task-section" id="this-week-card" style="margin-bottom:20px;">
      <div class="loading-text">載入中⋯</div>
    </div>

    <!-- 所有週任務列表 -->
    <div class="section-label">所有任務</div>
    <div id="all-weeks-wrap" style="margin-bottom:20px;">
      <div class="loading-text">載入中⋯</div>
    </div>

    <!-- Milestones -->
    <div class="section-label">近期 Milestones</div>
    <div class="card" id="ms-card" style="margin-bottom:20px;">
      <div class="loading-text">載入中⋯</div>
    </div>

    <!-- 行事曆 -->
    <div class="section-label">本月行事曆</div>
    <div class="cal-wrap" id="cal-wrap" style="grid-template-columns:1fr;"></div>

    <!-- 進度回報 -->
    <div class="section-label">週進度回報</div>
    <div class="card progress-card">
      <p>每週請在 GitHub Issues 填寫進度回報。點下方按鈕開啟回報表單。</p>
      <a class="report-btn" id="report-btn" href="#" target="_blank" rel="noopener">
        填寫本週進度回報 →
      </a>
    </div>

  </main>

  <script>
    // ────────────────────────────────────────────────────────────
    // 此頁專屬常數:組 ID。其餘設定全部從 teams.json 載入。
    // ────────────────────────────────────────────────────────────
    const TEAM_ID = 'team:b';

    // ── 系統共用設定 ──
    const OWNER = 'seraphwu';
    const REPO = 'grad-project-2026';
    const START = new Date('2026-02-23T00:00:00+08:00');
    const END = new Date('2027-01-03T23:59:59+08:00');
    const TOTAL_WKS = 45;

    // 組資訊由 loadTeam() 填入
    let TEAM_NAME = '';
    let MEMBERS = [];

    const $ = id => document.getElementById(id);
    const tw = () => new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Taipei' }));

    function roleToText(role) {
      if (Array.isArray(role)) return role.join(' / ');
      return role || '';
    }
    function ghHandle(github) {
      if (!github) return '';
      return github.startsWith('@') ? github : '@' + github;
    }

    async function loadTeam() {
      try {
        const res = await fetch('../../shared/teams.json', { cache: 'no-cache' });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        const team = data.teams && data.teams[TEAM_ID];
        if (!team) throw new Error(`teams.json 中找不到 ${TEAM_ID}`);
        TEAM_NAME = team.display_name || TEAM_ID;
        MEMBERS = team.members || [];

        // 更新 DOM 上跟組相關的東西
        document.title = `畢製管理 · ${TEAM_NAME}`;
        $('hd-badge').textContent = TEAM_NAME;
        $('hero-tname').textContent = TEAM_NAME;

        // 進度回報按鈕的 label 參數
        const labelParam = encodeURIComponent(TEAM_ID);
        $('report-btn').href =
          `https://github.com/${OWNER}/${REPO}/issues/new?template=progress.yml&labels=${labelParam}`;
      } catch (e) {
        console.warn('[teams.json] 載入失敗:', e.message);
        showError(`teams.json 載入失敗（${e.message}）。組別資訊無法顯示。`);
      }
    }

    function weekInfo() {
      const now = tw();
      const diff = now - START;
      const days = Math.floor(diff / 86400000);
      if (days < 0) return { before: true, daysUntil: -days };
      if (now > END) return { after: true };
      const week = Math.floor(days / 7) + 1;
      const dayOfWeek = (days % 7) + 1;
      const pct = Math.min(100, Math.round((days / (TOTAL_WKS * 7)) * 100));
      return { week, dayOfWeek, pct };
    }

    // ── Token ──
    let ghToken = localStorage.getItem('gh_pat') || '';
    function applyToken() {
      const v = $('tok-input').value.trim();
      if (v) { ghToken = v; localStorage.setItem('gh_pat', v); }
      $('rate-hint').textContent = ghToken ? 'PAT 已套用' : '未認證';
      loadAll();
    }
    if (ghToken) {
      document.addEventListener('DOMContentLoaded', () => {
        const el = $('tok-input');
        if (el) el.value = ghToken;
        $('rate-hint').textContent = 'PAT 已套用';
      });
    }

    async function ghFetch(path) {
      const headers = { Accept: 'application/vnd.github+json' };
      if (ghToken) headers.Authorization = `Bearer ${ghToken}`;
      const r = await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/${path}`, { headers });
      const rem = r.headers.get('X-RateLimit-Remaining');
      const lim = r.headers.get('X-RateLimit-Limit');
      if (rem !== null) $('hd-rate').textContent = `API ${rem}/${lim}`;
      if (!r.ok) throw new Error(`${r.status} ${r.statusText}`);
      return r.json();
    }

    async function fetchTeamIssues() {
      let page = 1, acc = [];
      while (true) {
        const batch = await ghFetch(`issues?state=all&labels=${encodeURIComponent(TEAM_ID)}&per_page=100&page=${page}`);
        if (!batch.length) break;
        acc = acc.concat(batch);
        if (batch.length < 100) break;
        page++;
      }
      return acc;
    }

    async function fetchMilestones() {
      return await ghFetch('milestones?state=all&per_page=100&sort=due_on&direction=asc');
    }

    const labels = i => i.labels.map(l => l.name);
    const issueWeek = i => labels(i).find(l => /^W\d+$/.test(l)) || null;
    const isBlocked = i => labels(i).includes('status:blocked');
    const isReview = i => labels(i).includes('status:review');

    // ── Clock ──
    function updateClock() {
      $('hd-clock').textContent = tw().toLocaleString('zh-TW', {
        month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit'
      });
    }
    setInterval(updateClock, 30000);
    updateClock();

    // ── Hero ──
    function renderHero() {
      const info = weekInfo();
      $('hero-tname').textContent = TEAM_NAME || TEAM_ID;

      if (info.before) {
        $('hero-wnum').textContent = '—';
        $('hero-day').textContent = `${info.daysUntil} 天後啟動`;
        return;
      }
      if (info.after) {
        $('hero-wnum').textContent = '完成';
        $('hero-day').textContent = `共 ${TOTAL_WKS} 週`;
        $('hero-pct').textContent = '100%';
        $('hero-fill').style.width = '100%';
        return;
      }
      $('hero-wnum').textContent = `W${info.week}`;
      $('hero-day').textContent = `第 ${info.week} 週 · 第 ${info.dayOfWeek} 天`;
      $('hero-pct').textContent = `${info.pct}%`;
      $('hero-fill').style.width = `${info.pct}%`;
    }

    // ── Members ──
    function renderMembers() {
      const card = $('members-card');
      if (!MEMBERS || MEMBERS.length === 0) {
        card.innerHTML = `<div class="loading-text">尚未設定組員</div>`;
        return;
      }
      card.innerHTML = `
    <div class="members-list-grid">
      ${MEMBERS.map(m => {
        const handle = ghHandle(m.github);
        const ini = m.github ? m.github.slice(0, 2).toUpperCase() : '??';
        const role = roleToText(m.role) || '組員';
        const url = m.github ? `https://github.com/${m.github.replace('@', '')}` : '#';
        return `
          <a class="member-chip" href="${url}" target="_blank" rel="noopener">
            <div class="member-chip-avatar">${ini}</div>
            <div class="member-chip-info">
              <div class="member-chip-name">${handle}</div>
              <div class="member-chip-role">${role}</div>
            </div>
          </a>`;
      }).join('')}
    </div>`;
    }

    // ── Issue card HTML ──
    function issueCard(i) {
      const wk = issueWeek(i);
      const lbs = labels(i).filter(l => !l.startsWith('team:') && l !== wk).slice(0, 4);
      const state = i.state === 'closed'
        ? `<span class="chip ok" style="color:var(--ok);border-color:#7cbf9e;background:var(--ok-bg)">已完成</span>`
        : isBlocked(i)
          ? `<span class="chip blocked">卡關</span>`
          : isReview(i)
            ? `<span class="chip" style="color:var(--text-muted)">審核中</span>`
            : '';
      return `
    <a class="issue-item" href="${i.html_url}" target="_blank" rel="noopener">
      <span class="issue-num">#${i.number}</span>
      <div class="issue-body">
        <div class="issue-title-text">${i.title}</div>
        <div class="chips">
          ${lbs.map(l => `<span class="chip">${l}</span>`).join('')}
          ${state}
        </div>
      </div>
    </a>`;
    }

    // ── This week ──
    function renderThisWeek(issues) {
      const info = weekInfo();
      const card = $('this-week-card');
      if (!info.week) {
        card.innerHTML = `<div class="loading-text">尚未開始</div>`;
        return;
      }
      const wkTag = `W${info.week}`;
      const wkIss = issues.filter(i => labels(i).includes(wkTag));
      const open = wkIss.filter(i => i.state === 'open');
      const closed = wkIss.filter(i => i.state === 'closed');

      card.innerHTML = `
    <div class="task-week-header current-week">
      <span>${wkTag} · 本週任務</span>
      <span class="task-count-badge">${open.length} 進行 · ${closed.length} 完成</span>
    </div>
    <div class="issue-list">
      ${wkIss.length === 0
          ? `<div class="loading-text">本週暫無任務</div>`
          : wkIss.map(issueCard).join('')}
    </div>`;
    }

    // ── All weeks ──
    function renderAllWeeks(issues) {
      const wrap = $('all-weeks-wrap');
      const info = weekInfo();

      const byWeek = {};
      issues.forEach(i => {
        const w = issueWeek(i) || 'no-week';
        if (!byWeek[w]) byWeek[w] = [];
        byWeek[w].push(i);
      });

      const weekKeys = Object.keys(byWeek)
        .filter(k => k !== 'no-week')
        .sort((a, b) => {
          const na = parseInt(a.replace('W', ''));
          const nb = parseInt(b.replace('W', ''));
          return nb - na;
        });
      if (byWeek['no-week']) weekKeys.push('no-week');

      if (weekKeys.length === 0) {
        wrap.innerHTML = `<div class="loading-text">暫無任務</div>`;
        return;
      }

      wrap.innerHTML = weekKeys.map(wk => {
        const iss = byWeek[wk];
        const isCur = info.week && wk === `W${info.week}`;
        const open = iss.filter(i => i.state === 'open').length;
        const closed = iss.filter(i => i.state === 'closed').length;
        return `
      <div class="card task-section" style="margin-bottom:10px;">
        <div class="task-week-header ${isCur ? 'current-week' : ''}">
          <span>${wk === 'no-week' ? '未分週' : wk}</span>
          <span class="task-count-badge">${open} 進行 · ${closed} 完成</span>
        </div>
        <div class="issue-list">
          ${iss.map(issueCard).join('')}
        </div>
      </div>`;
      }).join('');
    }

    // ── Milestones (簡化版,只顯示「未來/進行中」最近 6 個) ──
    function renderMilestones(milestones) {
      const card = $('ms-card');
      if (!milestones || milestones.length === 0) {
        card.innerHTML = `<div class="loading-text">沒有 milestones</div>`;
        return;
      }
      const now = tw();
      const sorted = [...milestones].sort((a, b) => {
        if (!a.due_on && !b.due_on) return 0;
        if (!a.due_on) return 1;
        if (!b.due_on) return -1;
        return new Date(a.due_on) - new Date(b.due_on);
      });

      // 只取「還沒到期」或「最後幾個」: 顯示前後各 6 個共 6 個
      const upcoming = sorted.filter(m => !m.due_on || new Date(m.due_on) >= now).slice(0, 6);
      const display = upcoming.length > 0 ? upcoming : sorted.slice(-6);

      card.innerHTML = `<div class="ms-mini-list">${display.map(m => {
        const dueDate = m.due_on ? new Date(m.due_on) : null;
        const isPast = dueDate && dueDate < now && m.state !== 'closed';
        const dueText = dueDate
          ? dueDate.toLocaleDateString('zh-TW', { month: 'numeric', day: 'numeric' })
          : '—';
        const desc = m.description ? m.description.replace(/\n/g, ' ') : '—';
        return `
      <a class="ms-mini-item ${m.state === 'closed' || isPast ? 'past' : ''}"
         href="${m.html_url}" target="_blank" rel="noopener">
        <div class="ms-mini-title">${m.title}</div>
        <div class="ms-mini-desc">${desc}</div>
        <div class="ms-mini-due">${dueText}</div>
      </a>`;
      }).join('')}</div>`;
    }

    // ── Calendar ──
    // 把 milestones 攤平成 { 'YYYY-MM-DD': [{title, isOpen}] }
    function indexMilestonesByDay(milestones) {
      const map = {};
      if (!milestones) return map;
      for (const m of milestones) {
        if (!m.due_on) continue;
        const d = new Date(new Date(m.due_on).toLocaleString('en-US', { timeZone: 'Asia/Taipei' }));
        const ymd = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
        if (!map[ymd]) map[ymd] = [];
        map[ymd].push({ title: m.title, isOpen: m.state === 'open' });
      }
      return map;
    }

    function renderCalendar(issues, milestones) {
      const wrap = $('cal-wrap');
      const now = tw();
      const year = now.getFullYear();
      const month = now.getMonth();

      const issueDates = {};
      issues.forEach(i => {
        const d = new Date(new Date(i.created_at).toLocaleString('en-US', { timeZone: 'Asia/Taipei' }));
        if (d.getFullYear() === year && d.getMonth() === month) {
          const day = d.getDate();
          issueDates[day] = (issueDates[day] || 0) + 1;
        }
      });

      const msByDay = indexMilestonesByDay(milestones);

      const todayD = now.getDate();
      const firstDay = new Date(year, month, 1).getDay();
      const daysInMo = new Date(year, month + 1, 0).getDate();
      const prevDays = new Date(year, month, 0).getDate();
      const name = new Date(year, month).toLocaleString('zh-TW', { year: 'numeric', month: 'long' });
      const dayNames = ['日', '一', '二', '三', '四', '五', '六'];

      let cells = dayNames.map(d => `<div class="cal-dname">${d}</div>`).join('');
      for (let i = firstDay - 1; i >= 0; i--)
        cells += `<div class="cal-day other-month"><div class="cal-day-num">${prevDays - i}</div></div>`;
      for (let d = 1; d <= daysInMo; d++) {
        const cnt = issueDates[d] || 0;
        const dots = Math.min(cnt, 3);

        const ymd = `${year}-${String(month + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        const dayMs = msByDay[ymd] || [];
        const hasMs = dayMs.length > 0;
        const isPastDay = d < todayD;
        const allClosed = dayMs.length > 0 && dayMs.every(m => !m.isOpen);
        const msPast = hasMs && isPastDay && allClosed;

        const msClasses = hasMs ? `has-milestone${msPast ? ' ms-past' : ''}` : '';
        const msTitle = hasMs
          ? dayMs.map(m => m.isOpen ? m.title : `${m.title} (已關閉)`).join('\n')
          : '';
        const titleAttr = msTitle ? ` title="${msTitle.replace(/"/g, '&quot;')}"` : '';
        const msLabel = hasMs && !msPast
          ? (dayMs.length > 1
            ? `<div class="cal-ms-label">${dayMs[0].title} +${dayMs.length - 1}</div>`
            : `<div class="cal-ms-label">${dayMs[0].title}</div>`)
          : '';

        cells += `
      <div class="cal-day${d === todayD ? ' today' : ''}${cnt > 0 ? ' has-issues' : ''}${msClasses ? ' ' + msClasses : ''}"${titleAttr} style="${hasMs ? 'position:relative;' : ''}">
        <div class="cal-day-num">${d}</div>
        ${dots > 0 ? `<div class="cal-dots">${'<div class="cal-dot"></div>'.repeat(dots)}</div>` : ''}
        ${msLabel}
      </div>`;
      }
      const total = Math.ceil((firstDay + daysInMo) / 7) * 7;
      for (let i = firstDay + daysInMo, a = 1; i < total; i++, a++)
        cells += `<div class="cal-day other-month"><div class="cal-day-num">${a}</div></div>`;

      wrap.innerHTML = `
    <div class="card cal-card" style="max-width:400px;">
      <div class="cal-month-nav"><div class="cal-month-name">${name}</div></div>
      <div class="cal-grid">${cells}</div>
    </div>`;
    }

    // ── Error ──
    function showError(msg) {
      const b = $('error-box');
      b.textContent = msg;
      b.style.display = 'block';
    }

    // ── Load ──
    async function loadAll() {
      $('error-box').style.display = 'none';

      await loadTeam();
      renderHero();
      renderMembers();

      const [issuesResult, msResult] = await Promise.allSettled([
        fetchTeamIssues(),
        fetchMilestones()
      ]);

      let issues = [];
      if (issuesResult.status === 'fulfilled') {
        issues = issuesResult.value;
        renderThisWeek(issues);
        renderAllWeeks(issues);
      } else {
        showError(`GitHub API 錯誤：${issuesResult.reason.message}`);
        $('this-week-card').innerHTML = `<div class="loading-text">載入失敗</div>`;
        $('all-weeks-wrap').innerHTML = `<div class="loading-text">載入失敗</div>`;
      }

      let milestones = [];
      if (msResult.status === 'fulfilled') {
        milestones = msResult.value;
        renderMilestones(milestones);
      } else {
        $('ms-card').innerHTML = `<div class="loading-text">Milestones 載入失敗</div>`;
      }

      // calendar 兩個都需要;即使一個失敗也要渲染(那邊會顯示空)
      renderCalendar(issues, milestones);
    }

    loadAll();
  </script>
</body>

</html>